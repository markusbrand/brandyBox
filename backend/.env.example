# Brandy Box backend environment (copy to .env and set real values)
# .env is gitignored; never commit secrets.
#
# Local dev: `backend/.env` is auto-loaded by the app (see app/config.py). Run uvicorn
# from the `backend/` directory, or set the same variables in the process environment.

# Required: JWT signing (e.g. openssl rand -hex 32)
BRANDYBOX_JWT_SECRET=

# Storage and DB (defaults shown; DB path must be under container /data in Docker)
# BRANDYBOX_STORAGE_BASE_PATH=/mnt/shared_storage/brandyBox
# BRANDYBOX_DB_PATH=/data/brandybox.db
# Max storage for all users: percentage of drive (e.g. "70%") or fixed size (e.g. "500GB", "1TB"). Default: 70%
# BRANDYBOX_STORAGE_LIMIT=70%
# Optional: reject one upload larger than this many bytes (413). Example under Cloudflare Free 100 MB: 104857600
# BRANDYBOX_MAX_SINGLE_UPLOAD_BYTES=

# SMTP (for sending passwords to new users)
BRANDYBOX_SMTP_HOST=
BRANDYBOX_SMTP_PORT=587
BRANDYBOX_SMTP_USER=
BRANDYBOX_SMTP_PASSWORD=
BRANDYBOX_SMTP_FROM=

# First admin (created on first start)
BRANDYBOX_ADMIN_EMAIL=
BRANDYBOX_ADMIN_INITIAL_PASSWORD=

# CORS (comma-separated origins). Include every browser origin that must call the API (HTTPS tunnel + LAN if used).
# Example LAN + tunnel:
# BRANDYBOX_CORS_ORIGINS=https://brandybox.brandstaetter.rocks,http://192.168.0.150:8081

# Public base URL for Google OAuth redirect (no trailing slash). Must match what users type in the browser
# and what you register in Google Cloud Console under "Authorized redirect URIs" (exact string, one line):
#   {BRANDYBOX_PUBLIC_BASE_URL}/api/auth/google/callback
# Example: if this is https://brandybox.example.com then Google must list:
#   https://brandybox.example.com/api/auth/google/callback
# Error 400 redirect_uri_mismatch: Google has a different URI than the app sends — fix Google Console and/or
# set BRANDYBOX_PUBLIC_BASE_URL to that same origin (scheme + host + port). If you open the app via HTTPS
# tunnel, do not only register the LAN http://... callback unless you also sign in from that exact URL.
# BRANDYBOX_PUBLIC_BASE_URL=https://brandybox.brandstaetter.rocks

# Google OAuth (optional). If unset, the web login page hides "Continue with Google" (GET /api/meta/version has google_signin_available: false).
# Docker Compose: `docker-compose.yml` passes these into the container from this file; values only in .env are not visible to the app unless wired in compose.
# Users must already exist (admin-created) before they can use Google. Redirect URI in Google Cloud:
#   {BRANDYBOX_PUBLIC_BASE_URL}/api/auth/google/callback
# BRANDYBOX_GOOGLE_CLIENT_ID=
# BRANDYBOX_GOOGLE_CLIENT_SECRET=

# Built web SPA path inside the container (set by Docker image). Override only for custom layouts.
# BRANDYBOX_STATIC_DIST_PATH=/app/web_dist

# API version strings (shown in /api/meta/version and client ping)
# BRANDYBOX_API_VERSION=0.2.0
# BRANDYBOX_MIN_SUPPORTED_CLIENT_VERSION=0.1.0

# Prune server diagnostic events older than N days when writing new events (0 = skip prune)
# BRANDYBOX_SERVER_EVENTS_RETENTION_DAYS=30

# Optional: port (inside container, usually 8080), logging
# BRANDYBOX_PORT=8080
# BRANDYBOX_LOG_LEVEL=INFO

# Compose-only (not a BRANDYBOX_* var): host port published for API + web UI
# HOST_PORT=8081
